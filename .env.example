# Breco Safaris – Environment Variables
# Copy to .env.local and fill in values

# Database (Neon)
# Get from: console.neon.tech → your project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# Auth (self-hosted JWT)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-long-random-secret-min-64-chars

# Email (Resend)
RESEND_API_KEY=re_...

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SIGNUPS_ENABLED=false

#Imagekit
IMAGEKIT_PUBLIC_KEY=public_key
IMAGEKIT_PRIVATE_KEY=private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_APP_FOLDER=image_folder